{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liminal-hq.github.io/skills/schema/skill.schema.json",
  "title": "Skill Metadata",
  "type": "object",
  "required": [
    "name",
    "description",
    "version",
    "owners",
    "supported_agents",
    "required_files",
    "validation_commands",
    "required_tools",
    "optional_tools",
    "artefact_paths",
    "approval_requirements"
  ],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "owners": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "supported_agents": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "required_files": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "validation_commands": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "required_tools": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "optional_tools": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "artefact_paths": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "approval_requirements": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": true
}
